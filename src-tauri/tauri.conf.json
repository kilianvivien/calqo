{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Calqo",
  "version": "0.4.5",
  "identifier": "dev.calqo.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Calqo",
        "label": "main",
        "width": 1280,
        "height": 840,
        "minWidth": 980,
        "minHeight": 680,
        "visible": false,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 18, "y": 25 },
        "dragDropEnabled": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "GraphicsAndDesign",
    "shortDescription": "A simple, glass-native social visual maker",
    "longDescription": "Calqo is a local-first maker for static social posts, thumbnails, stories, and banners.",
    "copyright": "Copyright © 2026 Calqo contributors",
    "createUpdaterArtifacts": false,
    "icon": [
      "../public/calqo-icon.png",
      "../public/calqo-icon@2x.png"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-"
    }
  }
}
